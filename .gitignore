#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Environment variables
.env
.env.local
.env.*.local
# Keep .env.example tracked so new contributors know which keys to set.
!.env.example

# Signing and secrets (CI/CD)
android/key.properties
android/app/upload-keystore.jks
*.keystore
*.jks
*.p12
*.mobileprovision
ios/ExportOptions.plist
ios/AuthKey_*.p8

# Firebase project secrets — DO commit these per Flutter convention
# (Apple/Google APIs treat them as public client identifiers, but enforce
# bundle/SHA-1 + App Check restrictions on the Cloud Console). They are
# included intentionally; restrictions are documented in
# docs/setup/api-key-restrictions.md.
# - ios/Runner/GoogleService-Info.plist
# - android/app/google-services.json
# - lib/firebase_options.dart

# RevenueCat
# - lib/features/subscription/providers/subscription_provider.dart contains
#   the public SDK key; RevenueCat treats these as public. Do NOT hardcode
#   the secret API key (server-only) here — it lives in Firebase Functions
#   secret manager.
