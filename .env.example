# Aura Coach AI — environment variables template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Generation / rotation steps for each key are in
# docs/setup/api-key-restrictions.md.

# ── Gemini (Google Generative AI) ─────────────────────────────────────
# Generate at https://aistudio.google.com/apikey
# Apply restrictions: API key restrictions → Generative Language API only.
# Application restrictions → Android (SHA-1 fingerprints) + iOS (bundle id).
GEMINI_API_KEY=your-gemini-api-key-here

# ── (Optional, future) RevenueCat secret key ──────────────────────────
# Public SDK key is in `SubscriptionProvider.publicApiKey` and is safe
# to ship in the client. The secret key is server-only and should live
# in Firebase Functions secret manager — never in this file.
# REVENUECAT_SECRET_KEY=

# ── (Optional, future) Cloudinary upload preset ───────────────────────
# Used by AI illustration upload flow (Pro feature).
# CLOUDINARY_UPLOAD_PRESET=
# CLOUDINARY_CLOUD_NAME=
