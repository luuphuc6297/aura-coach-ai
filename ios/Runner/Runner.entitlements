<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Required by sign_in_with_apple plugin (v7+).
	     Must also be enabled in App Store Connect → Identifiers →
	     com.auracoach.aura_coach_ai → "Sign In with Apple" capability,
	     otherwise Apple sign-in returns
	     ASAuthorizationErrorUnknown / 1000 on real devices. -->
	<key>com.apple.developer.applesignin</key>
	<array>
		<string>Default</string>
	</array>
</dict>
</plist>
